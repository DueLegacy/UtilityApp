<UserControl x:Class="UtilityApp.Modules.BusinessRequirements.BusinessRequirementsModuleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="980"
             d:DesignHeight="520">
    <UserControl.Resources>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#FFD7E4EE" />
        <SolidColorBrush x:Key="HeadingBrush" Color="#FF1A2A35" />
        <SolidColorBrush x:Key="BodyBrush" Color="#FF455764" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FF1F6E7A" />
        <SolidColorBrush x:Key="GoodBrush" Color="#FF2A8D5C" />
        <SolidColorBrush x:Key="ErrorBrush" Color="#FFB24139" />

        <Style x:Key="SectionBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Padding" Value="16" />
            <Setter Property="Background" Value="#FFF8FBFF" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="AccentButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonRoot" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonRoot" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonRoot" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource AccentButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource HeadingBrush}" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource SectionBorderStyle}">
            <StackPanel>
                <TextBlock Text="AIO.py Report Module"
                           FontFamily="Bahnschrift"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource HeadingBrush}" />
                <TextBlock Margin="0,8,0,0"
                           Text="Runs the same workbook analysis as AIO.py and saves the result as stat.txt beside the selected workbook."
                           FontFamily="Segoe UI"
                           FontSize="13"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource BodyBrush}" />

                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="130" />
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="WorkbookPathTextBox"
                             Padding="10,8"
                             FontFamily="Consolas"
                             FontSize="12"
                             VerticalContentAlignment="Center"
                             TextChanged="WorkbookPathTextBox_TextChanged" />

                    <Button x:Name="BrowseWorkbookButton"
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            Content="Browse Workbook"
                            Style="{StaticResource GhostButtonStyle}"
                            Click="BrowseWorkbookButton_Click" />

                    <Button x:Name="UseDefaultWorkbookButton"
                            Grid.Column="2"
                            Margin="10,0,0,0"
                            Content="Use Default"
                            Style="{StaticResource GhostButtonStyle}"
                            Click="UseDefaultWorkbookButton_Click" />
                </Grid>

                <Grid Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="150" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Year" Style="{StaticResource FieldLabelStyle}" />
                        <TextBox x:Name="YearTextBox"
                                 Margin="0,8,0,0"
                                 Padding="10,8"
                                 FontFamily="Segoe UI"
                                 FontSize="13" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock Text="Period Type" Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox x:Name="PeriodTypeComboBox"
                                  Margin="0,8,0,0"
                                  Padding="6"
                                  FontFamily="Segoe UI"
                                  FontSize="13"
                                  SelectionChanged="PeriodTypeComboBox_SelectionChanged">
                            <ComboBoxItem Content="Month" Tag="m" />
                            <ComboBoxItem Content="Quarter" Tag="q" />
                            <ComboBoxItem Content="Semiannual" Tag="s" />
                            <ComboBoxItem Content="Annual" Tag="a" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="12,0,0,0">
                        <TextBlock Text="Value" Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox x:Name="PeriodValueComboBox"
                                  Margin="0,8,0,0"
                                  Padding="6"
                                  FontFamily="Segoe UI"
                                  FontSize="13" />
                    </StackPanel>

                    <StackPanel Grid.Column="3" Margin="12,0,0,0">
                        <TextBlock Text="Options" Style="{StaticResource FieldLabelStyle}" />
                        <CheckBox x:Name="ShowProgressCheckBox"
                                  Margin="0,12,0,0"
                                  Content="Show in-progress BR titles"
                                  FontFamily="Segoe UI"
                                  FontSize="13"
                                  Foreground="{StaticResource BodyBrush}" />
                    </StackPanel>

                    <TextBlock x:Name="StatusTextBlock"
                               Grid.Column="4"
                               Margin="16,20,16,0"
                               Text="Select a workbook and run analysis."
                               TextWrapping="Wrap"
                               FontFamily="Segoe UI"
                               FontSize="13"
                               Foreground="{StaticResource BodyBrush}"
                               VerticalAlignment="Center" />

                    <Button x:Name="RunAnalysisButton"
                            Grid.Column="5"
                            Margin="0,20,0,0"
                            Height="38"
                            Content="Run Analysis"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="RunAnalysisButton_Click" />
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Margin="0,14,0,0" Style="{StaticResource SectionBorderStyle}">
            <StackPanel>
                <TextBlock Text="Output"
                           FontFamily="Bahnschrift"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource HeadingBrush}" />
                <TextBlock Margin="0,8,0,0"
                           Text="The generated report is written as stat.txt in the same folder as the selected workbook."
                           FontFamily="Segoe UI"
                           FontSize="13"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource BodyBrush}" />

                <TextBlock Margin="0,16,0,0"
                           Text="Output File"
                           Style="{StaticResource FieldLabelStyle}" />
                <TextBlock x:Name="OutputFilePathTextBlock"
                           Margin="0,8,0,0"
                           FontFamily="Consolas"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource BodyBrush}" />

                <TextBlock Margin="0,16,0,0"
                           Text="Last Run"
                           Style="{StaticResource FieldLabelStyle}" />
                <TextBlock x:Name="LastRunSummaryTextBlock"
                           Margin="0,8,0,0"
                           FontFamily="Segoe UI"
                           FontSize="13"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource BodyBrush}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
