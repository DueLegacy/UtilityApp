<UserControl x:Class="UtilityApp.Modules.Templates.TemplatesModuleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="900"
             d:DesignHeight="600">
    <UserControl.Resources>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#FFD7E4EE" />
        <SolidColorBrush x:Key="HeadingBrush" Color="#FF1A2A35" />
        <SolidColorBrush x:Key="BodyBrush" Color="#FF455764" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FF1F6E7A" />
        <SolidColorBrush x:Key="AccentMutedBrush" Color="#FFE4F1F4" />
        <SolidColorBrush x:Key="DangerBrush" Color="#FFB24139" />

        <Style x:Key="AccentButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonRoot" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonRoot" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonRoot" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource AccentButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        </Style>

        <Style x:Key="DangerGhostButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource AccentButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
        </Style>

        <Style x:Key="TemplateListItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="{StaticResource BodyBrush}" />
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="ListItemBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="Transparent"
                                BorderBrush="#00000000"
                                BorderThickness="1"
                                CornerRadius="8">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ListItemBorder" Property="Background" Value="#FFF2F6FB" />
                                <Setter TargetName="ListItemBorder" Property="BorderBrush" Value="#FFD3E0ED" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ListItemBorder" Property="Background" Value="{StaticResource AccentMutedBrush}" />
                                <Setter TargetName="ListItemBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource HeadingBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="14" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Padding="14"
                Background="#FFF8FBFF"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Button x:Name="NewTemplateButton"
                            Width="110"
                            HorizontalAlignment="Right"
                            Content="New"
                            Style="{StaticResource GhostButtonStyle}"
                            Click="NewTemplateButton_Click" />
                </Grid>

                <Grid Grid.Row="1" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="TemplateSearchTextBox"
                             Padding="10,8"
                             FontFamily="Segoe UI"
                             FontSize="13"
                             TextChanged="TemplateSearchTextBox_TextChanged" />

                    <Border Grid.Column="1"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            Background="{StaticResource AccentMutedBrush}"
                            CornerRadius="10"
                            Padding="10,4">
                        <TextBlock x:Name="TemplateListCountText"
                                   Text="0"
                                   FontFamily="Bahnschrift"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}" />
                    </Border>
                </Grid>

                <ListBox x:Name="TemplateListBox"
                         Grid.Row="2"
                         Margin="0,12,0,0"
                         MinHeight="420"
                         BorderBrush="{StaticResource PanelBorderBrush}"
                         BorderThickness="1"
                         Background="#FFFAFCFF"
                         SelectionChanged="TemplateListBox_SelectionChanged" />
            </Grid>
        </Border>

        <Border Grid.Column="2"
                Padding="14"
                Background="#FFF8FBFF"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Template Editor"
                               FontFamily="Bahnschrift"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource HeadingBrush}" />
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button x:Name="CopyTemplateButton"
                                Width="104"
                                Margin="0,0,8,8"
                                Content="Copy"
                                Style="{StaticResource GhostButtonStyle}"
                                Click="CopyTemplateButton_Click" />
                        <Button x:Name="EditTemplateButton"
                                Width="104"
                                Margin="0,0,8,8"
                                Content="Edit"
                                Style="{StaticResource GhostButtonStyle}"
                                Click="EditTemplateButton_Click" />
                        <Button x:Name="DeleteTemplateButton"
                                Width="104"
                                Margin="0,0,0,8"
                                Content="Delete"
                                IsEnabled="False"
                                Style="{StaticResource DangerGhostButtonStyle}"
                                Click="DeleteTemplateButton_Click" />
                    </StackPanel>
                </Grid>

                <TextBlock Margin="0,14,0,0"
                           Text="Name"
                           FontFamily="Bahnschrift"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource HeadingBrush}" />
                <TextBox x:Name="TemplateNameTextBox"
                         Margin="0,8,0,0"
                         Padding="10,8"
                         FontFamily="Segoe UI"
                         FontSize="13"
                         IsReadOnly="True" />

                <TextBlock Margin="0,14,0,0"
                           Text="Content"
                           FontFamily="Bahnschrift"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource HeadingBrush}" />
                <TextBox x:Name="TemplateContentTextBox"
                         Margin="0,8,0,0"
                         MinHeight="420"
                         Padding="10"
                         FontFamily="Consolas"
                         FontSize="12"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />


            </StackPanel>
        </Border>
    </Grid>
</UserControl>




